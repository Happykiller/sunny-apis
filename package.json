{
  "name": "@happykiller/sunny-apis",
  "version": "0.6.1",
  "description": "Library front",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint",
    "format": "eslint --fix",
    "build": "rollup -c",
    "clean": "rm -rf dist",
    "check:externals": "node scripts/check-externals.js",
    "test": "env NODE_ENV=test jest --coverage --no-cache",
    "test:e2e": "env NODE_ENV=test jest --config jest.e2e.config.js",
    "test:watch": "env NODE_ENV=test jest --watch --coverage --no-cache",
    "build:link": "npm run exports:generate && npm run clean && npm run build && npm link",
    "exports:generate": "ts-node --project tsconfig.scripts.json scripts/generate-exports.ts",
    "release:patch": "npm run clean && npm run build && npm version patch && npm publish --access public",
    "release:minor": "npm run clean && npm run build && npm version minor && npm publish --access public",
    "release:major": "npm run clean && npm run build && npm version major && npm publish --access public"
  },
  "author": "fabrice.rosito@gmail.com",
  "license": "ISC",
  "devDependencies": {
    "@nestjs/apollo": "^13.1.0",
    "@nestjs/testing": "^11.1.0",
    "@rollup/plugin-commonjs": "^28.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^0.4.4",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.14",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "jest-mock-extended": "^4.0.0-beta1",
    "rollup": "^4.40.1",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/graphql": "^13.0.0",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/microservices": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/platform-socket.io": "^11.0.0",
    "@nestjs/websockets": "^11.0.0",
    "@passwordless-id/webauthn": "^2.3.0",
    "@types/crypto-js": "^4.2.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "crypto-js": "^4.2.0",
    "mongodb": "^6.16.0",
    "passport-jwt": "^4.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  }
}
